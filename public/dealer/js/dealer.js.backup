$(document).ready(function () {
  $.ajaxSetup({
    headers: {
      "X-CSRF-TOKEN": $('meta[name="csrf-token"]').attr("content"),
    },
  });

  /** Sidebar toggle */
  const sidebar = $(".sidebar-list");
  const submenus = sidebar.find("> ul > li > ul");

  // Ẩn tất cả submenu ban đầu
  submenus.hide();
  sidebar.find(".bi-caret-down").removeClass("rotate-180");

  // Nếu li có class active-parent và có ul con → mở sẵn
  sidebar.find("> ul > li.active-parent").each(function () {
    const submenu = $(this).find("> ul");
    if (submenu.length > 0) {
      submenu.show();
      $(this).find("> a .bi-caret-down").addClass("rotate-180");
    }
  });

  // Click vào parent link có submenu
  sidebar.find("> ul > li > a:has(.bi-caret-down)").on("click", function (e) {
    e.preventDefault();

    const submenu = $(this).next("ul");
    if (submenu.length === 0) return;

    const isOpen = submenu.is(":visible");

    // Đóng tất cả submenu khác
    submenus.slideUp(200);
    sidebar.find(".bi-caret-down").removeClass("rotate-180");

    // Toggle submenu hiện tại
    if (!isOpen) {
      submenu.slideDown(200);
      $(this).find(".bi-caret-down").addClass("rotate-180");
    }
  });

  // AJAX search + pagination
  function loadItems(params, keywordId, displayId, shimmer = { rows: 7, cols: 5 }) {
    const urlParams = new URLSearchParams();
    for (const key in params) {
      if (params[key] != null && params[key] !== "") urlParams.set(key, params[key]);
    }
    history.pushState({}, "", "?" + urlParams.toString());

    const shimmerRow = `<tr>
            ${Array(shimmer.cols).fill('<td><span class="loading-shimmer"></span></td>').join("")}
        </tr>`;
    $(`#${displayId}`).find("tbody").html(shimmerRow.repeat(shimmer.rows));

    $.ajax({
      url: $(`#${displayId}`).data("url"),
      data: params,
      headers: { "X-Requested-With": "XMLHttpRequest" },
      success: function (html) {
        $(`#${displayId}`).html(html);
        bindPaginationLinks(keywordId, displayId);
      },
    });
  }
  function bindPaginationLinks(keywordId, displayId) {
    $(`#${displayId}`)
      .find(".pagination a")
      .on("click", function (e) {
        e.preventDefault();
        const url = new URL($(this).attr("href"));
        const params = Object.fromEntries(url.searchParams.entries());
        const keyword = $(`#${keywordId}`).val().trim();
        loadItems({ ...params, keyword: keyword }, keywordId, displayId);
      });
  }
  // List for dealer/product
  let searchTimer;
  $("#search-keyword").on("input", function () {
    clearTimeout(searchTimer);
    const keyword = $(this).val().trim();
    searchTimer = setTimeout(function () {
      loadItems({ keyword: keyword }, "search-keyword", "product-table-container");
    }, 500);
  });
  bindPaginationLinks("search-keyword", "product-table-container");
  $("#clear-search").on("click", function () {
    $("#search-keyword").val("");
    loadItems({}, "search-keyword", "product-table-container");
  });

  // Toast bootstrap
  function showToast(type = "success", message) {
    const toastElement = $("#toastNotification");
    const toastHeader = toastElement.find(".toast-header");
    const toastBody = toastElement.find(".toast-body");

    toastHeader.removeClass("bg-success bg-danger").addClass(type === "success" ? "bg-success" : "bg-danger");
    toastBody.text(message);
    const toastOptions = {
      autohide: true,
      delay: 3000,
    };
    const toast = new bootstrap.Toast(toastElement[0], toastOptions);
    toast.show();
  }

  /**
   * Common dealer/cart
   *
   * */
  $(document).on("click", ".quantity .qty-minus", function () {
    const qtyInput = $(this).siblings(".qty-input");
    let currentValue = parseInt(qtyInput.val()) || 1;
    let minValue = parseInt(qtyInput.attr("min")) || 1;

    if (currentValue > minValue) {
      qtyInput.val(currentValue - 1);
    }
  });

  $(document).on("click", ".quantity .qty-plus", function () {
    const qtyInput = $(this).siblings(".qty-input");
    let currentValue = parseInt(qtyInput.val()) || 1;
    let maxValue = parseInt(qtyInput.attr("max")) || 999;

    if (currentValue < maxValue) {
      qtyInput.val(currentValue + 1);
    }
  });

  /**
   * Cart for dealer/cart
   *
   * */
  $(document).on("click", ".dealer-buy .btn-add-to-cart", function (event) {
    event.preventDefault();
    const btnAddToCart = $(event.currentTarget);
    const dealerBuy = btnAddToCart.closest(".dealer-buy");
    const productId = parseInt(dealerBuy.attr("data-product-id"), 10);
    const quantity = parseInt(dealerBuy.find(".qty-input").val(), 10) || 1;
    const url = dealerBuy.data("url");
    $.ajax({
      type: "POST",
      dataType: "json",
      url: url,
      data: { productId: productId, quantity: quantity },
      beforeSend: function () {
        $("#preloader").removeClass("d-none");
      },
      success: function (result) {
        $("#preloader").addClass("d-none");
        if (result.status == 1) {
          showToast("success", result.message);
        } else {
          showToast("error", result.message);
        }
      },
    });
  });
  function dealerUpdateToCart(url, itemId, quantity) {
    $.ajax({
      type: "POST",
      dataType: "json",
      url: url,
      data: { itemId: itemId, quantity: quantity },
      beforeSend: function () {
        $("#preloader").removeClass("d-none");
      },
      success: function (result) {
        $("#preloader").addClass("d-none");
        if (result.status == 1) {
          $(`#dealer-cart tr[data-item-id="${itemId}"]`).find(".subtotal").text(result.subtotal);
          $("#dealer-cart .total_amount").text(result.total_amount);
          $("#dealer-cart .total_amount_val").text(result.total_amount);
          showToast("success", result.message);
        } else {
          showToast("error", result.message);
        }
      },
    });
  }
  $(document).on("click", "#dealer-cart .qty-box", function () {
    const qtyInput = $(this).siblings(".qty-input");
    let qty = parseInt(qtyInput.val()) || 1;

    qtyInput.val(qty).trigger("change");
  });
  $(document).on("change input", "#dealer-cart .qty-input", function () {
    let qty = parseInt($(this).val()) || 1;
    if (qty < 1) qty = 1;
    $(this).val(qty);
    const url = $("#dealer-cart").data("url-update");
    const itemId = $(this).closest("tr").data("item-id");

    dealerUpdateToCart(url, itemId, qty);
  });
  $(document).on("click", "#dealer-cart .btn-delete-item", function (event) {
    event.preventDefault();
    const btnDelete = $(event.currentTarget);
    const itemId = parseInt(btnDelete.closest("tr").attr("data-item-id"), 10);
    const url = $("#dealer-cart").data("url-delete");
    $.ajax({
      type: "POST",
      dataType: "json",
      url: url,
      data: { itemId: itemId },
      beforeSend: function () {
        $("#preloader").removeClass("d-none");
      },
      success: function (result) {
        $("#preloader").addClass("d-none");
        if (result.status == 1) {
          $(`#dealer-cart tr[data-item-id="${itemId}"]`).remove();
          $("#dealer-cart .total_amount").text(result.total_amount);
          $("#dealer-cart .total_amount_val").text(result.total_amount);
          if (result.total_amount == 0) {
            $("#dealer-cart #dealer-cart-content").html(`<div class="d-flex flex-column align-items-center justify-content-center gap-3 mt-5">
                                <svg width="100" height="100" viewBox="0 0 100 100" fill="none"
                                    xmlns="http://www.w3.org/2000/svg">
                                    <path
                                        d="M50 100C77.6142 100 100 77.6142 100 50C100 22.3858 77.6142 0 50 0C22.3858 0 0 22.3858 0 50C0 77.6142 22.3858 100 50 100Z"
                                        fill="#F5F5F5"></path>
                                    <path d="M70 35H30L35 70H65L70 35Z" stroke="#C0C0C0" stroke-width="2"
                                        stroke-linecap="round" stroke-linejoin="round"></path>
                                    <path d="M40 35V30C40 27.2386 42.2386 25 45 25H55C57.7614 25 60 27.2386 60 30V35"
                                        stroke="#C0C0C0" stroke-width="2" stroke-linecap="round"
                                        stroke-linejoin="round">
                                    </path>
                                </svg>
                                <h3 class="fs-24 mt-4 mb-0">Giỏ hàng trống</h3>
                                <p class="text-muted">Bạn chưa có sản phẩm nào trong giỏ hàng</p>
                            </div>`);
          }
          showToast("success", result.message);
        } else {
          showToast("error", result.message);
        }
      },
    });
  });
  $("#dealer-checkout-form .btn-checkout-success").click(function (e) {
    e.preventDefault();
    const form = $("#dealer-checkout-form");
    form.find(".form-control").removeClass("is-invalid");
    form.find(".form-select").removeClass("is-invalid");
    form.find(".invalid-feedback").remove();
    $.ajax({
      type: form.attr("method"),
      dataType: "json",
      url: form.attr("action"),
      data: form.serialize(),
      beforeSend: function () {
        $("#preloader").removeClass("d-none");
      },
      success: function (result) {
        $("#preloader").addClass("d-none");
        if (result.status == 1) {
          showToast("success", result.message);
          setTimeout(function () {
            window.location.href = result.url;
          }, 1000);
        } else if (result.status == 99) {
          $.each(result.errors, function (key, error) {
            const input = form.find(`[name="${key}"]`);
            input.addClass("is-invalid");
            input.after(`<div class="invalid-feedback">${error[0]}</div>`);
            console.log(key, error);
          });
           form.find(".is-invalid").first().focus();
        } else {
          showToast("error", result.message);
        }
      },
    });
  });
  // Update  quantity change
  $(".dealer-product-detail .qty-minus-js").click(function () {
    const qtyInput = $(this).siblings(".qty-input");
    let currentValue = parseInt(qtyInput.val()) || 1;
    let minValue = parseInt(qtyInput.attr("min")) || 1;

    if (currentValue > minValue) {
      qtyInput.val(currentValue - 1);
    }
    qtyInput.trigger("change");
  });
  $(".dealer-product-detail .qty-plus-js").click(function () {
    const qtyInput = $(this).siblings(".qty-input");
    let currentValue = parseInt(qtyInput.val()) || 1;
    let maxValue = parseInt(qtyInput.attr("max")) || 999;

    if (currentValue < maxValue) {
      qtyInput.val(currentValue + 1);
    }
    qtyInput.trigger("change");
  });
  $(document).on("change input", ".dealer-product-detail .qty-input", function () {
    let qty = parseInt($(this).val()) || 1;
    if (qty < 1) qty = 1;
    $(this).val(qty);

    const price = parseFloat($(this).closest(".quantity").data("price")) || 0;
    const total = qty * price;

    $(this).closest(".dealer-product-detail").find(".subtotal-price").text(total.toLocaleString("vi-VN"));
  });
});
